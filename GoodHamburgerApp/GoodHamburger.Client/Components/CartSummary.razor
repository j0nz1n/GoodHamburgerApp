<h3>CartSummary</h3>
@using GoodHamburger.Api.Models
@using System.Globalization

<div class="sticky-top" style="top: 20px;">
    <div class="card border-0 shadow-lg">
        <div class="card-header bg-dark text-white p-3">
            <h4 class="mb-0"><i class="bi bi-receipt me-2"></i>Your Order</h4>
        </div>
        <div class="card-body p-0">
            @if (Order == null || !Order.OrderItems.Any())
            {
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-cart3 fs-1 d-block mb-2"></i>
                    <p>Your cart is empty</p>
                </div>
            }
            else
            {
                <ul class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
                    @foreach (var item in Order.OrderItems)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <div>
                                <h6 class="mb-0">@item.Name</h6>
                                <small class="text-muted">@item.Price.ToString("C", new CultureInfo("en-US"))</small>
                            </div>
                            <button class="btn btn-sm text-danger border-0" @onclick="() => OnRemoveItem.InvokeAsync(item)">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </li>
                    }
                </ul>

                <div class="p-3 bg-light border-top">
                    @{
                        var subtotal = Order.OrderItems.Sum(x => x.Price);
                        var totalDiscount = subtotal - Order.TotalPrice;
                    }
                    
                    <div class="d-flex justify-content-between mb-1 small text-muted">
                        <span>Subtotal:</span>
                        <span>@subtotal.ToString("C", new CultureInfo("en-US"))</span>
                    </div>

                    @if (totalDiscount > 0)
                    {
                        <div class="d-flex justify-content-between mb-1 text-success fw-bold small">
                            <span>Combo Discount:</span>
                            <span>- @totalDiscount.ToString("C", new CultureInfo("en-US"))</span>
                        </div>
                    }

                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <h5 class="mb-0">Total:</h5>
                        <h4 class="mb-0 text-danger fw-bold">@Order.TotalPrice.ToString("C", new CultureInfo("en-US"))</h4>
                    </div>

                    <button class="btn btn-success w-100 mt-3 py-2 fw-bold rounded-pill">FINISH</button>
                    <button class="btn btn-link btn-sm w-100 mt-2 text-muted text-decoration-none" @onclick="OnCancelOrder">Clear Cart</button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Order? Order { get; set; }
    [Parameter] public EventCallback<OrderItem> OnRemoveItem { get; set; }
    [Parameter] public EventCallback OnCancelOrder { get; set; }
}